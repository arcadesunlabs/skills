{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Workflow skills configuration",
  "type": "object",
  "required": ["project", "docs", "taskTracker"],
  "properties": {
    "project": {
      "type": "object",
      "required": ["name", "conventionsFile"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "conventionsFile": { "type": "string", "minLength": 1 }
      }
    },
    "docs": {
      "type": "object",
      "required": ["root", "indexFile", "domainMirror"],
      "properties": {
        "root": { "type": "string", "minLength": 1 },
        "indexFile": { "type": "string", "minLength": 1 },
        "domainMirror": { "type": "string", "minLength": 1 }
      }
    },
    "taskTracker": {
      "type": "object",
      "required": [
        "provider",
        "enabled",
        "cardKeyPrefix",
        "branchMatchesCardKey"
      ],
      "properties": {
        "provider": {
          "type": "string",
          "enum": ["trello", "linear", "github", "none"]
        },
        "enabled": { "type": "boolean" },
        "mcpServer": { "type": "string" },
        "cardKeyPrefix": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9]*$"
        },
        "branchMatchesCardKey": { "type": "boolean" },
        "trello": {
          "type": "object",
          "properties": {
            "boardName": { "type": "string" },
            "boardUrl": { "type": "string" },
            "boardId": { "type": "string" },
            "lists": {
              "type": "object",
              "properties": {
                "todo": { "$ref": "#/$defs/list" },
                "inProgress": { "$ref": "#/$defs/list" },
                "backlog": { "$ref": "#/$defs/list" },
                "done": { "$ref": "#/$defs/list" }
              }
            }
          }
        }
      }
    },
    "code": {
      "type": "object",
      "properties": {
        "appRoot": { "type": "string" },
        "lintCommand": { "type": "string" },
        "testCommand": { "type": "string" }
      }
    }
  },
  "$defs": {
    "list": {
      "type": "object",
      "required": ["name", "id"],
      "properties": {
        "name": { "type": "string" },
        "id": { "type": "string" }
      }
    }
  }
}
