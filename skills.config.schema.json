{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Workflow skills configuration",
  "type": "object",
  "required": ["project", "docs"],
  "properties": {
    "project": {
      "type": "object",
      "required": ["name", "conventionsFile"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "conventionsFile": { "type": "string", "minLength": 1 }
      }
    },
    "docs": {
      "type": "object",
      "required": ["root", "indexFile", "domainMirror"],
      "properties": {
        "root": { "type": "string", "minLength": 1 },
        "indexFile": { "type": "string", "minLength": 1 },
        "domainMirror": { "type": "string", "minLength": 1 }
      }
    },
    "code": {
      "type": "object",
      "properties": {
        "appRoot": { "type": "string" }
      }
    },
    "workflow": {
      "type": "object",
      "properties": {
        "implementationFlow": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["phase"],
            "properties": {
              "phase": { "type": "string", "minLength": 1 },
              "skills": {
                "type": "array",
                "items": { "type": "string" }
              },
              "notes": { "type": "string" },
              "appliesTo": {
                "type": "array",
                "items": { "type": "string" }
              },
              "dependsOn": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "validationCommands": {
          "type": "array",
          "items": { "type": "string" }
        },
        "review": { "type": "string" },
        "docsFinalization": { "type": "string" }
      }
    }
  }
}
