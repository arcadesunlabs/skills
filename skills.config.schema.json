{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Workflow skills configuration",
  "type": "object",
  "required": ["project", "docs", "taskTracker", "implementation"],
  "properties": {
    "project": {
      "type": "object",
      "required": ["name", "conventionsFile"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "conventionsFile": { "type": "string", "minLength": 1 }
      }
    },
    "docs": {
      "type": "object",
      "required": ["root"],
      "properties": {
        "root": { "type": "string" },
        "indexFile": { "type": "string" },
        "domainMirror": { "type": "string" }
      }
    },
    "taskTracker": {
      "type": "object",
      "required": [
        "provider",
        "enabled",
        "cardKeyPrefix",
        "branchMatchesCardKey"
      ],
      "properties": {
        "provider": {
          "type": "string",
          "enum": ["trello", "jira", "linear", "github", "none"]
        },
        "enabled": { "type": "boolean" },
        "mcpServer": { "type": "string" },
        "cardKeyPrefix": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9]*$"
        },
        "branchMatchesCardKey": { "type": "boolean" },
        "trello": {
          "type": "object",
          "properties": {
            "boardName": { "type": "string" },
            "boardUrl": { "type": "string" },
            "boardId": { "type": "string" },
            "lists": {
              "type": "object",
              "properties": {
                "todo": { "$ref": "#/$defs/list" },
                "inProgress": { "$ref": "#/$defs/list" },
                "backlog": { "$ref": "#/$defs/list" },
                "done": { "$ref": "#/$defs/list" }
              }
            }
          }
        },
        "jira": {
          "type": "object",
          "properties": {
            "siteUrl": { "type": "string" },
            "projectKey": { "type": "string" },
            "boardId": { "type": "string" },
            "mcpServer": { "type": "string" },
            "issueTypes": {
              "type": "object",
              "properties": {
                "epic": { "type": "string" },
                "story": { "type": "string" },
                "task": { "type": "string" }
              }
            },
            "statuses": {
              "type": "object",
              "properties": {
                "todo": { "type": "string" },
                "inProgress": { "type": "string" },
                "backlog": { "type": "string" },
                "done": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "code": {
      "type": "object",
      "properties": {
        "appRoot": { "type": "string" },
        "lintCommand": { "type": "string" },
        "testCommand": { "type": "string" }
      }
    },
    "implementation": {
      "type": "object",
      "required": ["phases"],
      "properties": {
        "preset": {
          "type": "string",
          "enum": ["minimal", "frontend-ui-first", "api-first", "custom"]
        },
        "phases": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "notes": { "type": "string" },
              "optional": { "type": "boolean" },
              "alwaysLast": { "type": "boolean" }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "list": {
      "type": "object",
      "required": ["name", "id"],
      "properties": {
        "name": { "type": "string" },
        "id": { "type": "string" }
      }
    }
  }
}
