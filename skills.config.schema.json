{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Workflow skills configuration",
  "type": "object",
  "required": ["project", "docs"],
  "properties": {
    "project": {
      "type": "object",
      "required": ["name", "conventionsFile"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "conventionsFile": { "type": "string", "minLength": 1 }
      }
    },
    "docs": {
      "type": "object",
      "required": ["root", "indexFile"],
      "properties": {
        "root": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?![\\\\/])(?![A-Za-z]:[\\\\/])(?!\\.\\.(?:[\\\\/]|$))(?!.*[\\\\/]\\.\\.(?:[\\\\/]|$)).+$",
          "description": "Workspace-relative root for behavior-first project documentation."
        },
        "indexFile": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?![\\\\/])(?![A-Za-z]:[\\\\/])(?!\\.\\.(?:[\\\\/]|$))(?!.*[\\\\/]\\.\\.(?:[\\\\/]|$)).+$",
          "description": "Workspace-relative canonical navigation file for documentation structure, conventions, and links to domains, use cases, actors, capabilities, architecture, and other entry points."
        },
        "capabilitiesRoot": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?![\\\\/])(?![A-Za-z]:[\\\\/])(?!\\.\\.(?:[\\\\/]|$))(?!.*[\\\\/]\\.\\.(?:[\\\\/]|$)).+$",
          "description": "Folder under docs.root for rules shared by multiple use cases."
        }
      },
      "additionalProperties": false
    },
    "code": {
      "type": "object",
      "properties": {
        "appRoot": { "type": "string" },
        "searchRoots": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    },
    "workflow": {
      "type": "object",
      "properties": {
        "implementationFlow": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["phase"],
            "properties": {
              "phase": { "type": "string", "minLength": 1 },
              "skills": {
                "type": "array",
                "items": { "type": "string" }
              },
              "notes": { "type": "string" },
              "appliesTo": {
                "type": "array",
                "items": { "type": "string" }
              },
              "dependsOn": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "validationCommands": {
          "type": "array",
          "items": { "type": "string" }
        },
        "review": { "type": "string" },
        "docsFinalization": { "type": "string" }
      }
    }
  }
}
